generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  bio          String?
  avatarUrl    String?
  skills       String[]
  interests    String[]
  availability String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  applications TaskApplication[]
  badges       UserBadge[]
  reviews      Review[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String
  logoUrl     String?
  website     String?
  causeArea   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  reviews     Review[]
}

model Task {
  id              String            @id @default(cuid())
  title           String
  description     String
  skillsRequired  String[]
  causeArea       String
  timeEstimate    Int
  urgency         Urgency           @default(MEDIUM)
  status          TaskStatus        @default(OPEN)
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  applications    TaskApplication[]
  reviews         Review[]
}

model TaskApplication {
  id          String            @id @default(cuid())
  userId      String
  taskId      String
  status      ApplicationStatus @default(APPLIED)
  hoursLogged Float?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id])
  task        Task              @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  criteria    String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model Review {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  taskId         String?
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task?        @relation(fields: [taskId], references: [id])
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}
